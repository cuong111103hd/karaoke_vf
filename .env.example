# Environment configuration template
# Copy to .env and adjust values as needed

# Local storage path relative to project root or absolute
DATA_DIR=data

# Demucs separator model name (e.g., htdemucs, htdemucs_ft)
DEMUCS_MODEL_NAME=htdemucs

# Separation Engine Configuration
# Engine type: demucs or mdx_onnx
SEPARATION_ENGINE=demucs
# Model filename/identifier (leave empty for engine default)
SEPARATION_MODEL=
# Local model cache directory (Docker Compose overrides this with /app/models/separation)
SEPARATION_MODEL_DIR=data/models

# MDX Inference settings
MDX_SEGMENT_SIZE=256
MDX_OVERLAP=0.25
MDX_BATCH_SIZE=1

# Output format for the final karaoke audio (e.g., wav, mp3)
OUTPUT_FORMAT=wav

# Live source mode: streaming starts processing as soon as each source chunk
# window is available; download keeps the older full-file download/normalize path.
LIVE_SOURCE_MODE=streaming

# Local FastAPI server configuration
HOST=127.0.0.1
PORT=8000

# Docker Compose ports and resource limits
BACKEND_PORT=8000
FRONTEND_PORT=5173
BACKEND_CPUS=4.0
BACKEND_MEMORY=5g
INFERENCE_THREADS=2
FRONTEND_CPUS=0.5
FRONTEND_MEMORY=256m
