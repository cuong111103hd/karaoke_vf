# Environment configuration template
# Copy to .env and adjust values as needed

# Local storage path relative to project root or absolute
DATA_DIR=data

# Demucs separator model name (e.g., htdemucs, htdemucs_ft)
DEMUCS_MODEL_NAME=htdemucs

# Output format for the final karaoke audio (e.g., wav, mp3)
OUTPUT_FORMAT=wav

# Local FastAPI server configuration
HOST=127.0.0.1
PORT=8000

# Docker Compose ports and resource limits
BACKEND_PORT=8000
FRONTEND_PORT=5173
BACKEND_CPUS=4.0
BACKEND_MEMORY=5g
INFERENCE_THREADS=2
FRONTEND_CPUS=0.5
FRONTEND_MEMORY=256m
